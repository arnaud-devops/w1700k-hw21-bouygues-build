From: Gilly <gilroyscott1970@gmail.com>
Subject: [PATCH] wifi: mt76: mt7996: check pointer returned by mt76_connac_get_he_phy_cap

Backport of Lorenzo Bianconi's linux-wireless series (3/4).
mt76_connac_get_he_phy_cap() may return NULL. Two sites in mt7996/mcu.c
deref it unconditionally:
 - mt7996_mcu_bss_he_tlv(): add an early return on NULL cap.
 - mt7996_mcu_sta_bfer_he(): the !vc guard already existed but ve was
   computed as &vc->he_cap_elem before the check; fetch and validate the
   capability before taking the deref.

--- a/mt7996/mcu.c
+++ b/mt7996/mcu.c
@@ -852,6 +852,8 @@
 	struct tlv *tlv;
 
 	cap = mt76_connac_get_he_phy_cap(phy->mt76, vif);
+	if (!cap)
+		return;
 
 	tlv = mt7996_mcu_add_uni_tlv(skb, UNI_BSS_INFO_HE_BASIC, sizeof(*he));
 
@@ -1651,17 +1653,18 @@
 {
 	struct ieee80211_sta_he_cap *pc = &link_sta->he_cap;
 	struct ieee80211_he_cap_elem *pe = &pc->he_cap_elem;
-	const struct ieee80211_sta_he_cap *vc =
-		mt76_connac_get_he_phy_cap(phy->mt76, vif);
-	const struct ieee80211_he_cap_elem *ve = &vc->he_cap_elem;
 	u16 mcs_map = le16_to_cpu(pc->he_mcs_nss_supp.rx_mcs_80);
 	u8 nss_mcs = mt7996_mcu_get_sta_nss(mcs_map);
+	const struct ieee80211_he_cap_elem *ve;
+	const struct ieee80211_sta_he_cap *vc;
 	u8 snd_dim, sts;
 
+	vc = mt76_connac_get_he_phy_cap(phy->mt76, vif);
 	if (!vc)
 		return;
 
 	bf->tx_mode = MT_PHY_TYPE_HE_SU;
+	ve = &vc->he_cap_elem;
 
 	mt7996_mcu_sta_sounding_rate(bf, phy);
 
