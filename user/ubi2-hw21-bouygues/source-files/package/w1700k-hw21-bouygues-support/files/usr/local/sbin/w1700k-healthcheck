#!/bin/sh

set -u

failures=0
warnings=0

pass() {
	printf 'PASS  %s\n' "$*"
}

warn() {
	printf 'WARN  %s\n' "$*"
	warnings=$((warnings + 1))
}

fail() {
	printf 'FAIL  %s\n' "$*"
	failures=$((failures + 1))
}

check_command() {
	label="$1"
	shift
	if "$@" >/dev/null 2>&1; then
		pass "$label"
	else
		fail "$label"
	fi
}

printf 'W1700K HW2.1 Bouygues v2 health check\n'
# shellcheck disable=SC1091
printf 'release=%s kernel=%s\n' \
	"$(. /etc/openwrt_release 2>/dev/null; printf '%s' "${DISTRIB_REVISION:-unknown}")" \
	"$(uname -r)"

if grep -Fq '971-net-airoha-sync-UPDMEM-source-MAC-for-offloaded-IPv6.patch' /build_info 2>/dev/null; then
	pass 'patch 971 is recorded in build provenance'
else
	fail 'patch 971 is missing from build provenance'
fi
if grep -Fq '965-net-airoha-disable-hw-offload-for-ipv6-vlan-uplink-only.patch' /build_info 2>/dev/null; then
	fail 'fallback patch 965 is present in build provenance'
else
	pass 'fallback patch 965 is absent'
fi

for device in wan lan2; do
	driver="$(readlink "/sys/class/net/$device/phydev/driver" 2>/dev/null || true)"
	case "$driver" in
		*RTL8261CE*) pass "$device uses the RTL8261CE driver" ;;
		*) fail "$device RTL8261CE binding (found: ${driver:-none})" ;;
	esac
	carrier="$(cat "/sys/class/net/$device/carrier" 2>/dev/null || true)"
	speed="$(cat "/sys/class/net/$device/speed" 2>/dev/null || true)"
	if [ "$carrier" = 1 ]; then
		pass "$device carrier up at ${speed:-unknown} Mbit/s"
	else
		warn "$device carrier is down"
	fi
done

if [ "$(uci -q get firewall.@defaults[0].flow_offloading)" = 1 ]; then
	pass 'software flow offload enabled'
else
	fail 'software flow offload disabled'
fi
if [ "$(uci -q get firewall.@defaults[0].flow_offloading_hw)" = 1 ]; then
	pass 'hardware flow offload enabled'
else
	fail 'hardware flow offload disabled'
fi
if nft list chain inet fw4 forward 2>/dev/null |
	grep -Fq 'meta l4proto { tcp, udp } flow add @ft'; then
	pass 'normal dual-stack fw4 rule active'
else
	fail 'normal dual-stack fw4 rule missing'
fi

check_command 'dnsproxy service running' /etc/init.d/dnsproxy status
if nslookup openwrt.org 127.0.0.1:5353 >/dev/null 2>&1; then
	pass 'local DoQ proxy answers'
else
	fail 'local DoQ proxy does not answer'
fi
if [ "$(uci -q get dhcp.@dnsmasq[0].server)" = '127.0.0.1#5353' ]; then
	pass 'dnsmasq forwards to dnsproxy'
else
	fail 'dnsmasq is not chained to dnsproxy'
fi

configured_aps=0
for section in $(uci -q show wireless 2>/dev/null |
	sed -n 's/^wireless\.\([^.=]*\)=wifi-iface$/\1/p'); do
	[ "$(uci -q get "wireless.$section.mode")" = ap ] || continue
	[ "$(uci -q get "wireless.$section.disabled")" = 1 ] && continue
	configured_aps=$((configured_aps + 1))
done
hostapd_aps="$(ubus list 'hostapd.*' 2>/dev/null | awk 'END { print NR + 0 }')"
if [ "$configured_aps" -eq "$hostapd_aps" ]; then
	pass "$configured_aps configured APs have hostapd objects"
else
	fail "configured APs=$configured_aps hostapd objects=$hostapd_aps"
fi

if [ "$(uci -q get irqbalance.irqbalance.enabled)" = 1 ]; then
	check_command 'irqbalance enabled and running' /etc/init.d/irqbalance status
else
	warn 'irqbalance is disabled'
fi
check_command 'Watchcat running' /etc/init.d/watchcat status

/usr/local/sbin/w1700k-pstore-collect --status || warn 'pstore is unavailable'

printf 'summary failures=%s warnings=%s\n' "$failures" "$warnings"
[ "$failures" -eq 0 ]
